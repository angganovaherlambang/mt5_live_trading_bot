# MT5 Trading Bot — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# === TELEGRAM NOTIFICATIONS (optional) ===
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your chat ID — message your bot, then visit:
# https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates  (look for "id" inside "chat")
TELEGRAM_CHAT_ID=
